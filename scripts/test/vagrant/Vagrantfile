# Parameterized Vagrantfile for ServerKit E2E tests.
# The orchestrator passes config via env vars and uses one working dir
# per VM so multiple distros can coexist without colliding.
#
# Required env vars:
#   SK_BOX       e.g. "generic/debian12"
#   SK_VM_NAME   e.g. "sk-test-debian12-20260517-120000"
#
# Optional:
#   SK_CPUS      default 2
#   SK_MEMORY_MB default 4096

box_name  = ENV['SK_BOX']     || abort("SK_BOX env var is required")
vm_name   = ENV['SK_VM_NAME'] || abort("SK_VM_NAME env var is required")
cpus      = (ENV['SK_CPUS']      || '2').to_i
memory_mb = (ENV['SK_MEMORY_MB'] || '4096').to_i

Vagrant.configure("2") do |config|
  config.vm.box      = box_name
  config.vm.hostname = vm_name
  config.vm.define vm_name

  # No synced folders — we transfer files via vagrant scp/upload instead.
  # Default rsync sync slows boot and can fail on Windows hosts.
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "hyperv" do |hv|
    hv.vmname  = vm_name
    hv.cpus    = cpus
    hv.memory  = memory_mb
    hv.maxmemory = memory_mb
    hv.enable_virtualization_extensions = false
    hv.linked_clone = true
  end

  # Bootstrap: ensure rsync + curl are present (mirrors the multipass
  # cloud-init). Best effort — different distros use different package
  # managers, so try them in order.
  config.vm.provision "shell", inline: <<-SHELL
    set -e
    if command -v apt-get >/dev/null 2>&1; then
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -qq && apt-get install -y -qq rsync curl
    elif command -v dnf >/dev/null 2>&1; then
      dnf install -y -q rsync curl
    elif command -v yum >/dev/null 2>&1; then
      yum install -y -q rsync curl
    fi
  SHELL
end
