{
  "name": "serverkit-tramo",
  "display_name": "Automations",
  "version": "1.0.0",
  "description": "Node-based automation builder powered by tramo. Design workflows on a visual canvas (triggers, actions, branches, loops, approval gates) that react to panel events or run on a schedule, with 21 brand integration packs (Telegram, GitHub, Gmail, Discord, Notion, Stripe, Cloudflare, Postgres, Twilio and more). Enabled workflows deploy to a managed tramo container on the panel host that runs them headless, with run history, approvals, and inbound webhooks proxied through the panel. This replaces the older drag-and-drop Workflow Builder.",
  "author": "ServerKit",
  "license": "MIT",
  "category": "deployment",
  "homepage": "https://github.com/jhd3197/ServerKit",
  "permissions": [
    "docker",
    "shell",
    "filesystem",
    "network"
  ],
  "min_panel_version": "1.7.0",
  "entry_point": "tramo:tramo_bp",
  "url_prefix": "/api/v1/tramo",
  "models": "models:register",
  "lifecycle": {
    "install": "lifecycle:on_install",
    "uninstall": "lifecycle:on_uninstall"
  },
  "jobs": [
    {
      "kind": "tramo.harvest_runs",
      "handler": "jobs:harvest_runs"
    },
    {
      "kind": "tramo.health_check",
      "handler": "jobs:health_check"
    }
  ],
  "schedules": [
    {
      "name": "tramo-harvest-runs",
      "kind": "tramo.harvest_runs",
      "interval_seconds": 120
    },
    {
      "name": "tramo-health-check",
      "kind": "tramo.health_check",
      "interval_seconds": 300
    }
  ],
  "icon": "<circle cx=\"18\" cy=\"5\" r=\"3\"/><circle cx=\"6\" cy=\"12\" r=\"3\"/><circle cx=\"18\" cy=\"19\" r=\"3\"/><path d=\"M8.59 13.51l6.83 3.98\"/><path d=\"M15.41 6.51l-6.82 3.98\"/>",
  "contributions": {
    "nav": [
      {
        "id": "automations",
        "label": "Automations",
        "route": "/automations",
        "category": "operations",
        "icon": "<circle cx=\"18\" cy=\"5\" r=\"3\"/><circle cx=\"6\" cy=\"12\" r=\"3\"/><circle cx=\"18\" cy=\"19\" r=\"3\"/><path d=\"M8.59 13.51l6.83 3.98\"/><path d=\"M15.41 6.51l-6.82 3.98\"/>"
      }
    ],
    "routes": [
      {
        "path": "automations",
        "component": "AutomationsPage"
      },
      {
        "path": "automations/:tab",
        "component": "AutomationsPage"
      },
      {
        "path": "automations/edit/:slug",
        "component": "AutomationEditorPage",
        "layout": "full"
      }
    ],
    "page_titles": {
      "/automations": "Automations"
    },
    "command_palette": [
      {
        "label": "Automations",
        "path": "/automations",
        "category": "Pages",
        "keywords": "automation workflow tramo trigger action schedule webhook telegram github integration pipeline event"
      }
    ]
  }
}
